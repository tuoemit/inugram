From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: alina sireneva <alina@tei.su>
Date: Fri, 24 Apr 2026 13:35:21 +0300
Subject: prevent tapping the chat preview from expanding it to avoid accidentally opening it, and also make the bubbles interactive while we're at it

---
 TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java | 4 ++--
 .../src/main/java/org/telegram/ui/DialogsActivity.java        | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java
@@ -39520,12 +39520,12 @@ public class ChatActivity extends BaseFragment implements
 
         @Override
         public boolean canPerformActions() {
-            return actionBar != null && !actionBar.isActionModeShowed() && !isReport() && !inPreviewMode;
+            return actionBar != null && !actionBar.isActionModeShowed() && !isReport() && (!inPreviewMode || InuConfig.DISABLE_CHAT_PREVIEW_EXPAND.getValue());
         }
 
         @Override
         public boolean canPerformReply() {
-            return !isReport() && !inPreviewMode;
+            return !isReport() && (!inPreviewMode || InuConfig.DISABLE_CHAT_PREVIEW_EXPAND.getValue());
         }
 
         @Override
diff --git a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
@@ -8679,7 +8679,7 @@ public class DialogsActivity extends BaseFragment implements NotificationCenter.
             } else {
                 presentFragmentAsPreviewWithMenu(chatActivity[0] = new ChatActivity(args), previewMenu[0]);
                 if (chatActivity[0] != null) {
-                    chatActivity[0].allowExpandPreviewByClick = true;
+                    chatActivity[0].allowExpandPreviewByClick = !desu.inugram.InuConfig.DISABLE_CHAT_PREVIEW_EXPAND.getValue();
                     try {
                         chatActivity[0].getAvatarContainer().getAvatarImageView().performAccessibilityAction(AccessibilityNodeInfo.ACTION_ACCESSIBILITY_FOCUS, null);
                     } catch (Exception ignore) {
