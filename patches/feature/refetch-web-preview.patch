@@ -14071,6 +14075,34 @@ public class ChatActivity extends BaseFragment implements
 
     private HashMap<String, TLRPC.WebPage> lastLinkPreviewResults;
 
+    public void inu_refetchWebPreview() {
+        if (chatActivityEnterView == null) return;
+        CharSequence text = chatActivityEnterView.getFieldText();
+        if (TextUtils.isEmpty(text)) return;
+        foundWebPage = null;
+        foundUrls = null;
+        if (lastLinkPreviewResults != null) {
+            lastLinkPreviewResults.clear();
+        }
+        chatActivityEnterView.setWebPage(null, true);
+        if (editingMessageObject != null && editingMessageObject.messageOwner != null && editingMessageObject.messageOwner.media instanceof TLRPC.TL_messageMediaWebPage) {
+            editingMessageObject.messageOwner.media.manual = false;
+        }
+        String firstUrl = null;
+        try {
+            Matcher m = AndroidUtilities.WEB_URL.matcher(text);
+            if (m.find()) firstUrl = text.subSequence(m.start(), m.end()).toString();
+        } catch (Exception ignore) {}
+        if (firstUrl != null) {
+            TLRPC.TL_webPagePending pending = new TLRPC.TL_webPagePending();
+            pending.url = firstUrl;
+            pending.display_url = firstUrl;
+            pendingLinkSearchString = firstUrl;
+            showFieldPanelForWebPage(true, pending, false);
+        }
+        searchLinks(text, true, true);
+    }
+
     private void requestLinkPreviewCached(TL_account.getWebPagePreview req, Utilities.Callback2<Boolean, TLRPC.WebPage> done) {
