diff --git a/TMessagesProj/src/main/java/org/telegram/ui/Components/PhotoFilterView.java b/TMessagesProj/src/main/java/org/telegram/ui/Components/PhotoFilterView.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/Components/PhotoFilterView.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/Components/PhotoFilterView.java
@@ -1218,6 +1218,31 @@ public class PhotoFilterView extends FrameLayout implements FilterShaders.Filter
         }
     }
 
+    public void inu_enableSoftenSkin() {
+        if (softenSkinTool != -1) {
+            return;
+        }
+        softenSkinTool = 0;
+        enhanceTool++;
+        exposureTool++;
+        contrastTool++;
+        saturationTool++;
+        warmthTool++;
+        fadeTool++;
+        highlightsTool++;
+        shadowsTool++;
+        vignetteTool++;
+        if (grainTool != -1) grainTool++;
+        sharpenTool++;
+        tintShadowsTool++;
+        tintHighlightsTool++;
+        rowsCount++;
+        if (recyclerListView != null && recyclerListView.getAdapter() != null) {
+            recyclerListView.getAdapter().notifyItemInserted(0);
+            recyclerListView.scrollToPosition(0);
+        }
+    }
+
