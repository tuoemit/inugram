                 if (destCell != null) {
                     destCell.setVisibility(View.VISIBLE);
                 }
                 if (anchorSendButton != null && !sent) {
-                    anchorSendButton.setAlpha(1f);
+                    anchorSendButton.setAlpha(open && desu.inugram.InuConfig.DISABLE_SCRIM_BLUR.getValue() ? 0f : 1f);
