@@ -1723,13 +1725,13 @@ public class MessageSendPreview extends Dialog implements NotificationCenter.Not
                     closing = false;
                 }
                 if (editText != null) {
-                    editText.setAlpha(1f);
+                    editText.setAlpha(open && desu.inugram.InuConfig.DISABLE_SCRIM_BLUR.getValue() ? 0f : 1f);
